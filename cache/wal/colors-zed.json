{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0e152190",
                "editor.background": "#0e152190",
                "editor.foreground": "#c2c4c7",
                "text": "#c2c4c7",
                "text.muted": "#c2c4c770",
                "text.ignored": "#c2c4c740",
                "text.placeholder": "#c2c4c750",
                "ignored": "#c2c4c730",
                "element.hover": "#c2c4c730",
                "ghost_element.hover": "#433C4230",
                "ghost_element.selected": "#433C4230",
                "ghost_element.active": "#433C4260",
                "border": "#0e1521",
                "editor.highlighted_line.background": "#433C4210",
                "editor.active_line.background": "#433C4210",
                "panel.background": "#0e152190",
                "title_bar.background": "#0e152190",
                "title_bar.inactive_background": "#0e152190",
                "status_bar.background": "#0e152190",
                "drop_target.background": "#0e152190",
                "elevated_surface.background": "#0e1521",
                "toolbar.background": "#0e152190",
                "tab_bar.background": "#0e152190",
                "tab.inactive_background": "#0e152190",
                "tab.active_background": "#433C4230",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0e1521",
                "scrollbar.thumb.background": "#433C42",
                "editor.gutter.background": "#0e152190",
                "terminal.background": "#0e152110",
                "terminal.foreground": "#c2c4c7",
                "terminal.dim_foreground": "#c2c4c7",
                "terminal.bright_foreground": "#c2c4c7",
                "terminal.ansi.black": "#0e1521",
                "terminal.ansi.red": "#433C42",
                "terminal.ansi.green": "#675549",
                "terminal.ansi.yellow": "#88613C",
                "terminal.ansi.blue": "#8D7257",
                "terminal.ansi.magenta": "#A48C6D",
                "terminal.ansi.cyan": "#C8A171",
                "terminal.ansi.white": "#c2c4c7",
                "terminal.ansi.bright_black": "#5d6472",
                "terminal.ansi.bright_red": "#433C42",
                "terminal.ansi.bright_green": "#675549",
                "terminal.ansi.bright_yellow": "#88613C",
                "terminal.ansi.bright_blue": "#8D7257",
                "terminal.ansi.bright_magenta": "#A48C6D",
                "terminal.ansi.bright_cyan": "#C8A171",
                "terminal.ansi.bright_white": "#c2c4c7",
                "modified": "#433C42",
                "syntax": {
                    "attribute": {
                        "color": "#433C42"
                    },
                    "boolean": {
                      "color": "#675549"
                    },
                    "comment": {
                      "color": "#5d6472"
                    },
                    "comment.doc": {
                      "color": "#5d6472"
                    },
                    "constant": {
                      "color": "#675549"
                    },
                    "function": {
                      "color": "#C8A171"
                    },
                    "keyword": {
                      "color": "#8D7257"
                    },
                    "number": {
                      "color": "#A48C6D"
                    },
                    "operator": {
                      "color": "#8D7257"
                    },
                    "string": {
                      "color": "#433C42"
                    },
                    "variable": {
                      "color": "#675549"
                    }
                },
                "players": [
                  {
                    "cursor": "#433C42",
                    "background": "#0e1521",
                    "selection": "#433C4230"
                  }
                ]
            }
        }
    ]
}
